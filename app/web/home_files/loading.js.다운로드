function Fr_ToGetDay(startDateStr, endDateStr){

	var dateStartStr = startDateStr.replace(/-/gi,"");
	var dateEndStr = endDateStr.replace(/-/gi,"");
	
	var startYear=Number(dateStartStr.substring(0,4));
	var startMonth=Number(dateStartStr.substring(4,6));
	var startDay=Number(dateStartStr.substring(6));
	
	var endYear=Number(dateEndStr.substring(0,4));
	var endMonth=Number(dateEndStr.substring(4,6));
	var endDay=Number(dateEndStr.substring(6));
	
	var startDt = new Date(startYear,startMonth-1,startDay);
	var endDt = new Date(endYear,endMonth-1,endDay);
	
	var resultDt = Math.floor(endDt.valueOf()/(24*60*60*1000)- startDt.valueOf()/(24*60*60*1000));
	
	return resultDt;
	
}


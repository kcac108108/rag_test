function reverseData(input_data, key, type){//input_data : JSON 배열. key 이용해서 역순 정렬.
	 var temp_data = [];//복사될 배열
	 var data = {}; 
	 if(input_data !=undefined){//배열 복사
		 for(var i=0;i<input_data.length;i++){
			 data = input_data[i];
			 temp_data.push(JSON.parse(JSON.stringify(data)));//temp_data_로 복사
		 }
		if(type == "DATE"){	 
			temp_data.sort(function(a,b){//temp_data_ 역순정렬
				var date_a = (a[key]).replace(/[^0-9]/g,"");
				var date_b = (b[key]).replace(/[^0-9]/g,"");
				return date_a - date_b;
			});
		}else{
			;
		}
	 }
	// console.log(temp_data);
	return temp_data;
}

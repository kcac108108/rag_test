/** 
 * 작성자  : 정서빈
 * param : 쿠키명, 쿠키값, 만료일, 특정 시
 * desc  : 현재 날짜로 부터 +expiredays 의 absoluteTime 에 만료되는 지속쿠키 생성
 * */
function setCookie(name, value, expiredays, absoluteTime) { 
	
	var todayDate = new Date();
	var expireDate = null;
	
	if(absoluteTime == null){
		expireDate = new Date(todayDate.getFullYear(),todayDate.getMonth(),todayDate.getDate() + expiredays);
	}else{
		//특정시 기준
		expireDate = new Date(todayDate.getFullYear(),todayDate.getMonth(),todayDate.getDate() + expiredays,absoluteTime,0,0 );
	}
    document.cookie = name + "=" + escape(value) + "; path=/; expires=" + expireDate.toGMTString() + ";"; 
}
/** 
 * 작성자  : 정서빈
 * param : 쿠키명
 * desc  : name 과 일치하는 쿠키명이 있을 시 'return value'
 * */
function getCookie( name ){
	var nameOfCookie = name + "=";
	var x = 0;
	
	while (x <= document.cookie.length) {
		var y = (x+nameOfCookie.length);
		if (document.cookie.substring( x, y ) == nameOfCookie) {
			if ((endOfCookie=document.cookie.indexOf( ";", y )) == -1) {
				endOfCookie = document.cookie.length;
			}
			return unescape(document.cookie.substring(y, endOfCookie));
		}
		x = document.cookie.indexOf(" ", x ) + 1;
		if (x==0) {
			break;
		}
	}
	return "";
}



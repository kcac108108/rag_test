	var _url = window.location.href.split("?");
	var _params = _url[1].split("&");
	var _temp = "";
	var typeNewCheck = false;
	var cYearCheck = false;
	for(var i=0;i<_params.length;i++){
		
		var key = "";
		var value ="";
		if(_params[i].split("=").length == 2){
			key = _params[i].split("=")[0];
			if(key == "cYear"){
				value = year+"";
			}else{
				value = _params[i].split("=")[1];	
			}
			
			if(key == "type"){
				typeNewCheck = true;		
			}
			if(key == "cYear"){
				cYearCheck = true;		
			}
			
		}else{
			key = _params[i].split("=")[0];
